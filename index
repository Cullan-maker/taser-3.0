<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Taser 7 - Elite Tactical v7.40</title>
    <style>
        * { box-sizing: border-box; }
        body { 
            font-family: 'Segoe UI', sans-serif; background-color: #050505; color: #ecf0f1; 
            display: flex; flex-direction: column; align-items: center; padding: 10px; margin: 0; min-height: 100vh; overflow: hidden; 
        }
        h1.main-title { color: #f1c40f; margin: 5px; font-size: 16px; letter-spacing: 3px; text-transform: uppercase; }

        /* ----- VIEWPORT ----- */
        .viewport {
            width: 100%; height: 320px; border: 3px solid #1a1a1a; border-radius: 12px;
            position: relative; overflow: hidden; box-shadow: 0 15px 40px rgba(0,0,0,0.9);
            background-color: #0a0a0a; transition: all 0.3s ease;
        }
        #three-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 5; }
        .camera-feed { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; display: none; }

        /* ----- HUD ----- */
        .fixed-aim-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 9000; }
        .crosshair { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.2); border-radius: 50%; }
        .laser-green { position: absolute; width: 8px; height: 8px; background-color: #00ff00; border-radius: 50%; box-shadow: 0 0 15px #00ff00; top: 50%; left: 50%; transform: translate(-50%, -50%); display: none; }
        .laser-red { position: absolute; width: 8px; height: 8px; background-color: #ff0000; border-radius: 50%; box-shadow: 0 0 15px #ff0000; left: 50%; transform: translateX(-50%); display: none; }

        #nmi-overlay {
            display: none; position: absolute; top: 35%; left: 50%; transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.9); border: 2px solid #2ecc71; border-radius: 8px;
            padding: 15px; text-align: center; z-index: 10000; width: 260px; backdrop-filter: blur(10px);
        }
        #nmi-overlay.fail { border-color: #e74c3c; }

        /* ----- SCENARIO MODAL ----- */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 30000; justify-content: center; align-items: center; }
        .modal-content { background: #1a1a1a; padding: 25px; border-radius: 15px; border: 2px solid #f1c40f; width: 90%; max-width: 400px; text-align: center; }
        .scenario-btn { width: 100%; padding: 12px; margin: 8px 0; border-radius: 8px; border: 1px solid #333; background: #2c3e50; color: white; font-weight: bold; cursor: pointer; text-align: left; }
        .scenario-btn:hover { background: #34495e; border-color: #f1c40f; }
        .scenario-btn span { display: block; font-size: 10px; font-weight: normal; color: #bdc3c7; margin-top: 4px; }

        /* ----- DEVICE & CONTROLS ----- */
        .taser-device { 
            width: 280px; height: 160px; background: #c0392b; border-radius: 30px 30px 10px 10px; 
            position: relative; border: 4px solid #000; box-shadow: inset 0 5px 15px rgba(255,255,255,0.2);
            background-image: linear-gradient(45deg, #a93226 25%, transparent 25%, transparent 50%, #a93226 50%, #a93226 75%, transparent 75%, transparent);
            background-size: 4px 4px; margin-top: -10px;
        }
        .display-bezel { background: #000; width: 140px; height: 60px; margin: 15px auto; border-radius: 8px; display: flex; justify-content: center; align-items: center; border: 2px solid #333; }
        .display-screen { color: #ffff00; font-family: monospace; font-size: 14px; font-weight: bold; }
        
        .sim-controls { width: 300px; background: #2c3e50; padding: 15px; border-radius: 0 0 15px 15px; margin-top: -10px; }
        .btn-grid-compact { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 5px; margin-top: 8px; }
        button.action-btn { background: #34495e; color: white; border: none; padding: 10px 2px; border-radius: 4px; font-size: 9px; font-weight: bold; cursor: pointer; text-transform: uppercase; }
        .btn-trigger { background: #e74c3c !important; width: 100%; padding: 15px !important; font-size: 14px !important; margin-top: 10px; box-shadow: 0 4px 0 #7b241c; }
        
        .safety-switch { width: 60px; height: 30px; background: #27ae60; border-radius: 15px; margin: 10px auto; position: relative; cursor: pointer; border: 2px solid #000; }
        .safety-switch::after { content: ''; position: absolute; width: 22px; height: 22px; background: white; border-radius: 50%; top: 2px; left: 2px; transition: 0.2s; }
        .safety-switch.unsafe { background: #e74c3c; }
        .safety-switch.unsafe::after { left: 32px; }

        body.webxr-mode .sim-controls { background: rgba(44, 62, 80, 0.8); border: none; }
        body.webxr-mode .main-title { display: none; }
    </style>
</head>
<body>

    <h1 class="main-title">TASER 7 ELITE</h1>
    
    <div class="viewport" id="viewport">
        <div id="three-canvas"></div>
        <video id="camera-feed" class="camera-feed" autoplay playsinline></video>
        
        <div class="fixed-aim-layer">
            <div class="crosshair"></div>
            <div id="laser-green" class="laser-green"></div>
            <div id="laser-red" class="laser-red"></div>
            <div id="lightning" style="position:absolute; width:100%; height:100%; background: radial-gradient(circle, rgba(255,255,255,0.2), transparent); display:none;"></div>
        </div>

        <div id="nmi-overlay">
            <h2 id="nmi-title" style="margin:0; color:#2ecc71;">NMI</h2>
            <p id="nmi-details" style="margin:10px 0 0 0; font-size:12px;"></p>
        </div>

        <div class="hud-overlay">
            <div class="hud-row">
                <div class="target-label" id="target-label">READY</div>
                <div class="dist-label" id="dist-label">3.0 M</div>
            </div>
            <div class="spread-label" id="spread-label" style="margin-top:5px; width:fit-content;">SPRIDNING: --</div>
            <div id="place-hint" class="place-hint">Hittar golv...</div>
        </div>
    </div>

    <div class="main-container" id="main-container">
        <div class="taser-device">
            <div class="display-bezel">
                <div id="taser-display" class="display-screen">READY</div>
            </div>
            <div id="safety-switch" class="safety-switch" onclick="toggleSafety()"></div>
        </div>

        <div class="sim-controls">
            <button class="action-btn btn-trigger" onclick="pressTrigger()">AVFYRA</button>
            
            <div class="btn-grid-compact">
                <button class="action-btn" onclick="toggleCassette()">Kassett</button>
                <button class="action-btn" onclick="toggleBattery()">Batteri</button>
                <button class="action-btn" onclick="resetSimulator()">♻️ Återställ</button>
            </div>

            <div id="secondary-controls">
                <div class="btn-grid-compact">
                    <button class="action-btn" onclick="toggleCamera()">📷 Kamera</button>
                    <button class="action-btn" onclick="openScenarioModal()">🌐 WebXR</button>
                    <button class="action-btn" onclick="togglePlaceMode()">📍 Placera</button>
                </div>
            </div>
        </div>
    </div>

    <div id="scenario-modal" class="modal-overlay">
        <div class="modal-content">
            <h2 style="color:#f1c40f; margin-top:0;">Välj Scenario</h2>
            <button class="scenario-btn" onclick="startTacticalXR('static')">1. STATISKT MÅL<span>Figuren står stilla på golvet. Fokus på precision.</span></button>
            <button class="scenario-btn" onclick="startTacticalXR('moving')">2. RÖRLIGT MÅL<span>Figuren rör sig i sidled (Strafing).</span></button>
            <button class="scenario-btn" onclick="startTacticalXR('charging')">3. ANSTORMNING<span>Figuren går aggressivt mot din position!</span></button>
            <button class="action-btn" onclick="closeModal()" style="margin-top:15px; width:100%; background:#c0392b;">Avbryt</button>
        </div>
    </div>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
        }
    }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
        import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

        // --- STATE ---
        let isSafe = true, hasBattery = true, chamber1 = "loaded", chamber2 = "loaded";
        let currentDistance = 3.0, activeChamber = 1, scenario = 'static';
        let figureFallen = false, figureVisible = true;
        let xrSession = null, hitTestSource = null, localSpace = null;
        let activeWires = [], envHits = [];
        let heavyClothing = true; // Risk för disconnect

        // --- THREE.JS SETUP ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x050505);
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / 320, 0.1, 100);
        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth - 20, 320);
        renderer.shadowMap.enabled = true;
        renderer.toneMapping = THREE.ACESFilmicToneMapping;
        document.getElementById('three-canvas').appendChild(renderer.domElement);

        const pmrem = new THREE.PMREMGenerator(renderer);
        scene.environment = pmrem.fromScene(new RoomEnvironment()).texture;

        const light = new THREE.DirectionalLight(0xffffff, 2);
        light.position.set(5, 10, 5);
        light.castShadow = true;
        scene.add(light);
        scene.add(new THREE.AmbientLight(0xffffff, 0.3));

        const taserGroup = new THREE.Group();
        scene.add(taserGroup);

        // --- LOAD MODEL ---
        const loader = new GLTFLoader();
        loader.load('ue_mannequin_retopology.glb', (gltf) => {
            const model = gltf.scene;
            model.scale.set(0.9, 0.9, 0.9);
            model.traverse(n => { 
                if(n.isMesh) {
                    n.material = new THREE.MeshStandardMaterial({ color: 0x27ae60, roughness: 0.5, metalness: 0.2 });
                    n.castShadow = true; n.name = "Body";
                }
            });
            taserGroup.add(model);
        });

        const placementMarker = new THREE.Mesh(
            new THREE.RingGeometry(0.2, 0.25, 32),
            new THREE.MeshBasicMaterial({ color: 0x00ff00, side: THREE.DoubleSide })
        );
        placementMarker.rotation.x = -Math.PI/2;
        placementMarker.visible = false;
        scene.add(placementMarker);

        // --- AUDIO ---
        const listener = new THREE.AudioListener();
        camera.add(listener);
        const sparkSound = new THREE.PositionalAudio(listener);
        // (Här skulle man normalt ladda en ljudfil, vi simulerar med AudioContext för enkelhetens skull i en fil)

        // --- LOGIC FUNCTIONS ---
        window.toggleSafety = () => {
            isSafe = !isSafe;
            document.getElementById('safety-switch').classList.toggle('unsafe', !isSafe);
            document.getElementById('secondary-controls').style.display = isSafe ? 'block' : 'none';
            updateDisplay();
        };

        window.toggleBattery = () => {
            hasBattery = !hasBattery;
            updateDisplay();
        };

        window.toggleCassette = () => {
            if(!isSafe) return;
            chamber1 = (chamber1 === "empty") ? "loaded" : "empty";
            chamber2 = chamber1;
            updateDisplay();
        };

        function updateDisplay() {
            const disp = document.getElementById('taser-display');
            if(!hasBattery) { disp.textContent = ""; return; }
            disp.textContent = isSafe ? "SAFE" : (chamber1 === "loaded" ? "READY" : "EMPTY");
            document.getElementById('laser-green').style.display = (!isSafe && hasBattery) ? 'block' : 'none';
            document.getElementById('laser-red').style.display = (!isSafe && hasBattery && chamber1 === "loaded") ? 'block' : 'none';
        }

        window.openScenarioModal = () => { document.getElementById('scenario-modal').style.display = 'flex'; };
        window.closeModal = () => { document.getElementById('scenario-modal').style.display = 'none'; };

        window.startTacticalXR = async (type) => {
            scenario = type;
            closeModal();
            if (!navigator.xr) return alert("WebXR stöds ej");
            const session = await navigator.xr.requestSession('immersive-ar', {
                requiredFeatures: ['hit-test', 'local-floor']
            });
            xrSession = session;
            renderer.xr.enabled = true;
            await renderer.xr.setSession(session);
            document.body.classList.add('webxr-mode');
            
            session.addEventListener('end', () => {
                document.body.classList.remove('webxr-mode');
                xrSession = null;
            });
        };

        window.pressTrigger = () => {
            if(isSafe || !hasBattery || chamber1 === "empty") return;
            
            // --- BALLISTIK BERÄKNING ---
            // Ju längre avstånd, desto mer "drop" får pilen
            const dropAmount = Math.pow(currentDistance, 2) * 0.005; // Fysisk simulering
            const spreadFactor = currentDistance * 0.12; // Taser 7 spridning 12 grader
            
            const raycaster = new THREE.Raycaster();
            const activeCam = renderer.xr.isPresenting ? renderer.xr.getCamera(camera) : camera;
            
            // Pil 1 (Övre - Grön laser)
            raycaster.setFromCamera(new THREE.Vector2(0, 0), activeCam);
            const hit1 = raycaster.intersectObject(taserGroup, true)[0];

            // Pil 2 (Nedre - Beräknad ballistik)
            const bottomDartNDC = new THREE.Vector2(0, -(spreadFactor + dropAmount) / 2);
            raycaster.setFromCamera(bottomDartNDC, activeCam);
            const hit2 = raycaster.intersectObject(taserGroup, true)[0];

            // --- NMI LOGIK ---
            if(hit1 && hit2) {
                const dist = hit1.point.distanceTo(hit2.point) * 100;
                let success = dist > 20;
                
                // Slumpmässig risk för "Heavy Clothing" disconnect
                if(heavyClothing && Math.random() > 0.8) {
                    success = false;
                    showNMIOverlay(false, "DISCONNECT: Tjocka kläder blockerar kontakt.");
                } else {
                    showNMIOverlay(success, success ? "BRA SPRIDNING" : "FÖR TÄT SPRIDNING", dist);
                }

                if(success) figureFallen = true;

                // Skapa kablar
                createWire(hit1.point, 1);
                createWire(hit2.point, 2);
            } else {
                // MISS - Kolla om vi träffar omgivningen (väggar) i WebXR
                showNMIOverlay(false, "MISS: Pilarna missade målet.");
            }

            chamber1 = "fired";
            updateDisplay();
        };

        function createWire(targetPoint, id) {
            const material = new THREE.LineBasicMaterial({ color: 0x95a5a6 });
            const geometry = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(), targetPoint]);
            const line = new THREE.Line(geometry, material);
            scene.add(line);
            activeWires.push({ line, target: targetPoint.clone(), id });
        }

        function showNMIOverlay(success, reason, spread = 0) {
            const ovl = document.getElementById('nmi-overlay');
            ovl.style.display = 'block';
            ovl.className = success ? '' : 'fail';
            document.getElementById('nmi-title').textContent = success ? "NMI UPPNÅDD" : "INGEN VERKAN";
            document.getElementById('nmi-details').innerHTML = `Avstånd: ${currentDistance.toFixed(1)}m<br>Spridning: ${spread.toFixed(0)}cm<br><i>${reason}</i>`;
            setTimeout(() => ovl.style.display = 'none', 3500);
        }

        window.resetSimulator = () => {
            figureFallen = false;
            taserGroup.rotation.x = 0;
            chamber1 = "loaded"; chamber2 = "loaded";
            activeWires.forEach(w => scene.remove(w.line));
            activeWires = [];
            updateDisplay();
            window.log("System återställt.");
        };

        // --- ANIMATION LOOP ---
        renderer.setAnimationLoop((timestamp, frame) => {
            // WebXR Hit-test för placering
            if (frame && xrSession) {
                if (!hitTestSource) {
                    xrSession.requestReferenceSpace('viewer').then(space => {
                        xrSession.requestHitTestSource({ space }).then(src => hitTestSource = src);
                    });
                }
                if (hitTestSource) {
                    const hits = frame.getHitTestResults(hitTestSource);
                    if (hits.length > 0) {
                        const pose = hits[0].getPose(renderer.xr.getReferenceSpace());
                        placementMarker.visible = true;
                        placementMarker.position.set(pose.transform.position.x, pose.transform.position.y, pose.transform.position.z);
                    }
                }
            }

            // --- SCENARIO RÖRELSE ---
            if(!figureFallen) {
                if(scenario === 'moving') {
                    taserGroup.position.x = Math.sin(timestamp / 1000) * 1.5;
                } else if (scenario === 'charging') {
                    taserGroup.position.z += 0.01;
                    if(taserGroup.position.z > 5) taserGroup.position.z = -2;
                }
            } else {
                // Fall-animation
                if(taserGroup.rotation.x > -Math.PI/2) taserGroup.rotation.x -= 0.1;
            }

            // Uppdatera kablar (sträck dem mellan kamera och träffpunkt)
            const activeCam = renderer.xr.isPresenting ? renderer.xr.getCamera(camera) : camera;
            activeWires.forEach(w => {
                const pos = w.line.geometry.attributes.position.array;
                const camPos = new THREE.Vector3(0, -0.2, -0.1).applyMatrix4(activeCam.matrixWorld);
                pos[0] = camPos.x; pos[1] = camPos.y; pos[2] = camPos.z;
                w.line.geometry.attributes.position.needsUpdate = true;
            });

            // Avståndsmätning
            if(taserGroup.visible) {
                currentDistance = activeCam.position.distanceTo(taserGroup.position);
                document.getElementById('dist-label').textContent = currentDistance.toFixed(1) + " M";
            }

            renderer.render(scene, camera);
        });

        window.toggleCamera = async () => {
            const feed = document.getElementById('camera-feed');
            if(feed.style.display === 'none') {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                feed.srcObject = stream;
                feed.style.display = 'block';
                scene.background = null;
                taserGroup.visible = false; // Fokus på riktig markör
            } else {
                feed.style.display = 'none';
                scene.background = new THREE.Color(0x050505);
                taserGroup.visible = true;
            }
        };

        window.togglePlaceMode = () => {
            taserGroup.position.copy(placementMarker.position);
            placementMarker.visible = false;
            window.log("Figur placerad.");
        };

    </script>
</body>
</html>
